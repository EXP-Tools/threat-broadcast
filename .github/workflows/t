name: Automatically crawl CVEs 
on:
  pull_request:
    branches:
      - master
  workflow_dispatch:
    branches:
      - master
  schedule:
    - cron: '0 0/3 * * *'

jobs:
  build-and-deploy:
    runs-on: ubuntu-latest
    permissions:
      contents: write
    
    steps:
      - name: Check out repo
        uses: actions/checkout@v4

      - name: Set up Python
        uses: actions/setup-python@v5
        with:
          python-version: '3.8'

      - name: Configure pip caching
        uses: actions/cache@v4
        with:
          path: ~/.cache/pip
          key: ${{ runner.os }}-pip-${{ hashFiles('**/requirements.txt') }}
          restore-keys: |
            ${{ runner.os }}-pip-

      - name: Install Python dependencies
        run: |
          python -m pip install -r requirements.txt

      - name: Crawl CVEs
        run: |-
          python main.py -g "${{ secrets.CRAWL_PWD }}" --gtk ${{ secrets.GRAPHQL_TOKEN }}

      - name: Commit and push Github page (if changed)
        if: ${{ github.event_name != 'pull_request' }}
        run: |-
          git diff
          git config --global user.email "github-bot@example.com"
          git config --global user.name "Github-Bot"
          git add -A
          git commit -m "Updated by Github Bot" || exit 0
          git push origin master
